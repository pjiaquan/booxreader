<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/readerSettingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <include
        android:id="@+id/settingsContent"
        layout="@layout/dialog_reader_settings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View
        android:id="@+id/settingsFooterDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:id="@+id/settingsFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_md">

        <Button
            android:id="@+id/btnSettingsCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/settings_button_height"
            android:text="@android:string/cancel"
            android:textAllCaps="false" />

        <Space
            android:layout_width="@dimen/settings_split_spacing"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSettingsSave"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/settings_button_height"
            android:text="@android:string/ok"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
